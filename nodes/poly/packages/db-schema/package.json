{
  "name": "@cogni/poly-db-schema",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./copy-trade": {
      "types": "./dist/copy-trade.d.ts",
      "import": "./dist/copy-trade.js",
      "default": "./dist/copy-trade.js"
    },
    "./wallet-connections": {
      "types": "./dist/wallet-connections.d.ts",
      "import": "./dist/wallet-connections.js",
      "default": "./dist/wallet-connections.js"
    },
    "./wallet-grants": {
      "types": "./dist/wallet-grants.d.ts",
      "import": "./dist/wallet-grants.js",
      "default": "./dist/wallet-grants.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"const fs=require('fs'); for(const f of ['dist/index.js','dist/copy-trade.js','dist/wallet-connections.js','dist/wallet-grants.js']){if(!fs.existsSync(f)){console.error('ERROR: '+f+' missing'); process.exit(1)}}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
