# Docker-internal overrides for docker:dev:stack / docker:test:stack.
# .env.local uses host-mode URLs (localhost:55432, localhost:3000).
# When running fully containerized, services reach each other by container name.
# This file is layered AFTER .env.local so these values win.

COGNI_REPO_PATH=/repo/current
DATABASE_URL=postgresql://app_user:password@postgres:5432/cogni_template_dev?sslmode=disable
DATABASE_SERVICE_URL=postgresql://app_service:service_password@postgres:5432/cogni_template_dev?sslmode=disable
COGNI_NODE_ENDPOINTS=operator=http://app:3000,poly=http://poly:3100,resy=http://resy:3300
APP_BASE_URL=https://localhost

# MCP server URLs — Docker-internal DNS (overrides .env.local localhost URLs)
MCP_GRAFANA_URL=http://grafana-mcp:8000/mcp
MCP_PLAYWRIGHT_URL=http://playwright-mcp:3003/mcp
# Reset config path — Docker image has config/mcp.servers.json at CWD
MCP_CONFIG_PATH=config/mcp.servers.json
