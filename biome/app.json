{
  "overrides": [
    {
      "includes": [
        "nodes/*/app/src/components/**/*.{ts,tsx}",
        "nodes/*/app/src/features/**/components/**/*.{ts,tsx}",
        "nodes/*/app/src/features/**/hooks/**/*.{ts,tsx}",
        "nodes/*/app/src/app/**/*.client.{ts,tsx}"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/ports/server"],
                    "message": "@/ports/server re-exports @cogni/scheduler-core (node:util) — server-only. Client components must use @/ports (client-safe barrel). See bug.0147."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "nodes/poly/app/src/**/*.{ts,tsx}",
        "!nodes/poly/app/src/bootstrap/capabilities/poly-trade.ts",
        "!nodes/poly/app/src/bootstrap/capabilities/poly-clob-creds.ts",
        "!nodes/poly/app/src/bootstrap/capabilities/poly-trade-executor.ts",
        "!nodes/poly/app/src/adapters/server/wallet/privy-poly-trader-wallet.adapter.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@polymarket/clob-client": "Legacy V1 SDK — use only from a legal importer. Provisioning CLOB API-key creation is isolated in poly-clob-creds.ts because the manual green chain still requires v1.",
                  "@polymarket/clob-client-v2": "Import only from poly-trade.ts, poly-clob-creds.ts, poly-trade-executor.ts, or privy-poly-trader-wallet.adapter.ts. Placement goes through PolyTradeCapability/Executor (task.0315 CP4.25)."
                }
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "nodes/*/app/src/app/**/page.tsx",
        "nodes/*/app/src/app/**/layout.tsx",
        "nodes/*/app/src/app/**/loading.tsx",
        "nodes/*/app/src/app/**/error.tsx",
        "nodes/*/app/src/app/**/not-found.tsx",
        "nodes/*/app/src/app/**/template.tsx",
        "nodes/*/app/src/app/**/global-error.tsx",
        "nodes/*/app/src/app/**/default.tsx",
        "nodes/*/app/src/app/**/opengraph-image.tsx",
        "nodes/*/app/src/app/**/twitter-image.tsx",
        "nodes/*/app/next.config.ts",
        "nodes/*/app/postcss.config.mjs",
        "nodes/*/drizzle.config.ts",
        "playwright.config.ts",
        "vitest.config.mts",
        "nodes/*/app/vitest.*.config.mts",
        "commitlint.config.cjs",
        "eslint.config.mjs",
        "eslint/*.config.mjs"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    }
  ]
}
