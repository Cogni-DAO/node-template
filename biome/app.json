{
  "overrides": [
    {
      "includes": [
        "src/components/**/*.{ts,tsx}",
        "src/features/**/components/**/*.{ts,tsx}",
        "src/features/**/hooks/**/*.{ts,tsx}",
        "src/app/**/*.client.{ts,tsx}"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/ports/server"],
                    "message": "@/ports/server re-exports @cogni/scheduler-core (node:util) — server-only. Client components must use @/ports (client-safe barrel). See bug.0147."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/app/**/page.tsx",
        "src/app/**/layout.tsx",
        "src/app/**/loading.tsx",
        "src/app/**/error.tsx",
        "src/app/**/not-found.tsx",
        "src/app/**/template.tsx",
        "src/app/**/global-error.tsx",
        "src/app/**/default.tsx",
        "src/app/**/opengraph-image.tsx",
        "src/app/**/twitter-image.tsx",
        "next.config.ts",
        "tailwind.config.ts",
        "drizzle.config.ts",
        "playwright.config.ts",
        "vitest.config.mts",
        "vitest.integration.config.mts",
        "vitest.stack.config.mts",
        "postcss.config.mjs",
        "commitlint.config.cjs",
        "eslint.config.mjs",
        "eslint/*.config.mjs"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    }
  ]
}
