apiVersion: v1
kind: Secret
metadata:
  name: sandbox-openclaw-secrets
  namespace: cogni-production
type: Opaque
stringData:
  OPENCLAW_GATEWAY_TOKEN: "REPLACE_WITH_PRODUCTION_OPENCLAW_GATEWAY_TOKEN"
  GITHUB_TOKEN: "REPLACE_WITH_PRODUCTION_OPENCLAW_GITHUB_RW_TOKEN"
  LITELLM_MASTER_KEY: "REPLACE_WITH_PRODUCTION_LITELLM_MASTER_KEY"
