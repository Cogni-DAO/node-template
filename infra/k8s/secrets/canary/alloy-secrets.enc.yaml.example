#
# Grafana Cloud credentials + app metrics bearer token for the canary k3s cluster.
# This file is a TEMPLATE. To activate GitOps secret delivery via ksops:
#   1. Copy this file to alloy-secrets.enc.yaml (same directory)
#   2. Fill in real values from Grafana Cloud → Connections → Data Sources
#   3. `sops --encrypt --in-place infra/k8s/secrets/canary/alloy-secrets.enc.yaml`
#   4. Commit the encrypted file. ksops (Argo CD repo-server sidecar) decrypts at sync.
#
# ksops is NOT end-to-end activated yet — .sops.yaml has placeholder age keys.
# Until ksops bootstrap completes (see docs/guides/alloy-loki-setup.md Part 1),
# the alloy DaemonSet is bootstrapped via manual `kubectl create secret`.
# Tracked as: scorecard entry in work/projects/proj.cicd-services-gitops.md
apiVersion: v1
kind: Secret
metadata:
  name: alloy-secrets
  namespace: cogni-canary
  labels:
    app.kubernetes.io/name: alloy
    app.kubernetes.io/part-of: cogni
    app.kubernetes.io/component: observability
type: Opaque
stringData:
  LOKI_WRITE_URL: "REPLACE_WITH_GC_LOKI_PUSH_URL"
  LOKI_USERNAME: "REPLACE_WITH_GC_NUMERIC_USER_ID"
  LOKI_PASSWORD: "REPLACE_WITH_GC_API_KEY_STARTING_WITH_glc_"
  PROMETHEUS_REMOTE_WRITE_URL: "REPLACE_WITH_GC_PROM_REMOTE_WRITE_URL"
  PROMETHEUS_USERNAME: "REPLACE_WITH_GC_NUMERIC_USER_ID"
  PROMETHEUS_PASSWORD: "REPLACE_WITH_GC_API_KEY_STARTING_WITH_glc_"
  METRICS_TOKEN: "REPLACE_WITH_APP_METRICS_BEARER_TOKEN"
