#
# SOPS-encrypted K8s Secret for scheduler-worker (staging).
# This file is a TEMPLATE — encrypt with `sops --encrypt --in-place` after
# replacing placeholder values with real secrets.
#
# DO NOT commit this file with plaintext secret values.
apiVersion: v1
kind: Secret
metadata:
  name: scheduler-worker-secrets
  namespace: cogni-staging
  labels:
    app.kubernetes.io/name: scheduler-worker
    app.kubernetes.io/part-of: cogni
type: Opaque
stringData:
  SCHEDULER_API_TOKEN: "REPLACE_WITH_STAGING_SCHEDULER_API_TOKEN"
  # DATABASE_URL — optional. Per task.0280, the scheduler path holds NO DB
  # credentials: runs/grants persistence is delegated to each node's internal
  # HTTP API. Only include DATABASE_URL here if this worker also runs the
  # attribution/ledger pipeline (follow-up will rename it to LEDGER_DATABASE_URL).
  # DATABASE_URL: "REPLACE_WITH_STAGING_LEDGER_DB_SERVICE_URL"
  # Optional — only needed if GitHub App ingestion is enabled
  # GH_REVIEW_APP_PRIVATE_KEY_BASE64: "REPLACE_WITH_BASE64_PEM"
