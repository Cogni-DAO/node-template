#
# PLAINTEXT TEMPLATE — NOT APPLIED DIRECTLY.
#
# Copy this file to `ghcr-secret.enc.yaml`, fill in the token value, then
# encrypt in place with SOPS (age recipient already configured in .sops.yaml
# at repo root). The `.enc.yaml` file is what kustomization.yaml references;
# ksops decrypts it at apply-time on the Argo CD repo-server side-car.
#
# Token: reuse the existing `GHCR_DEPLOY_TOKEN` org-level PAT (read:packages
# on ghcr.io/cogni-dao). See docs/runbooks/image-updater-bootstrap.md.
#
# Usage:
#   cp ghcr-secret.enc.yaml.example ghcr-secret.enc.yaml
#   # edit `ghcr-secret.enc.yaml`: replace <GHCR_DEPLOY_TOKEN> with the real value
#   sops --encrypt --in-place ghcr-secret.enc.yaml
#   git add ghcr-secret.enc.yaml
#
# Rotation: re-run the same three lines with the new token value, commit, then
#   kubectl rollout restart deployment/argocd-image-updater -n argocd
apiVersion: v1
kind: Secret
metadata:
  name: argocd-image-updater-ghcr
  namespace: argocd
  labels:
    app.kubernetes.io/name: argocd-image-updater
    app.kubernetes.io/part-of: argocd
type: Opaque
stringData:
  # `credentials: secret:argocd/argocd-image-updater-ghcr#token` in
  # config-patch.yaml reads this key. Format is `username:token` — same
  # shape Image Updater's registry docs show for ghcr.io.
  token: "Cogni-1729:<GHCR_DEPLOY_TOKEN>"
