#
# PLAINTEXT TEMPLATE — NOT APPLIED DIRECTLY.
#
# Copy this file to `git-creds-secret.enc.yaml`, fill in the PAT value, then
# encrypt in place with SOPS. The Image Updater reads this Secret when
# committing digest updates back to `main` via the annotation
# `write-back-method: git:secret:argocd/argocd-image-updater-git-creds`.
#
# PAT: reuse the existing `ACTIONS_AUTOMATION_BOT_PAT` (same token already
# used by release.yml / promote-to-production.yml / promote-and-deploy.yml /
# flight-preview.yml). Owner identity: Cogni-1729. Required scopes:
#   - `contents: write` on cogni-dao/cogni-template (already present)
#   - no other scope needed — Image Updater only touches files, not Actions
#
# Usage:
#   cp git-creds-secret.enc.yaml.example git-creds-secret.enc.yaml
#   # edit: replace <ACTIONS_AUTOMATION_BOT_PAT> with the real value
#   sops --encrypt --in-place git-creds-secret.enc.yaml
#   git add git-creds-secret.enc.yaml
#
# Rotation: re-run the same three lines with the new PAT, commit, then
#   kubectl rollout restart deployment/argocd-image-updater -n argocd
apiVersion: v1
kind: Secret
metadata:
  name: argocd-image-updater-git-creds
  namespace: argocd
  labels:
    app.kubernetes.io/name: argocd-image-updater
    app.kubernetes.io/part-of: argocd
type: Opaque
stringData:
  # Image Updater's git:secret: scheme reads `username` + `password` from
  # this Secret. GitHub HTTPS accepts "<pat>" or "<user>:<pat>" — we use the
  # split form for clarity and parity with the GHCR secret.
  username: "Cogni-1729"
  password: "<ACTIONS_AUTOMATION_BOT_PAT>"
