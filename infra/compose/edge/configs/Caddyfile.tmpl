{
  # ACME endpoint per environment. Validators iterate candidate-a frequently
  # — each cold-start provisions a fresh Caddy that requests a cert for the
  # same domain. Let's Encrypt PROD's 50-certs/week-per-registered-domain
  # rate limit gets eaten within a few days, after which TLS fails with
  # `internal error` (no cert in storage, ACME blocked by rate limit).
  # Default to STAGING (300/day per account, daily reset, untrusted by
  # browsers but works with `curl -k`). production env overrides to PROD.
  acme_ca {$ACME_CA:https://acme-staging-v02.api.letsencrypt.org/directory}

  log {
    level INFO
    format json
    output file /data/logs/caddy/caddy.log {
      roll_size 10MB
      roll_keep 7
      roll_keep_for 168h
    }
  }
}

# Redirect www to non-www (canonical domain)
www.{$DOMAIN} {
  redir https://{$DOMAIN}{uri} permanent
}

# ── Single-node fork (node-template) → k3s NodePort 30000 ───────────────
# bug.5001: this file used to carry separate operator / poly / resy site
# blocks with their own {$*_DOMAIN} keys. On single-node forks, the unused
# *_DOMAIN env vars render as bare `{` site openers → Caddy parser reads
# them as a global block out of order → fatal config error → restart loop.
# Single-node has exactly one domain, exactly one upstream — collapse to
# one site block. Multi-node forks should add additional blocks per node
# rather than reintroduce the empty-key pattern.
#
# Default upstream port is 30000 to match infra/catalog/node-template.yaml
# ::node_port — that's the SSOT. provision-env-vm.sh derives NODE_UPSTREAM
# from the same catalog field and writes it into /opt/cogni-template-edge/.env.
{$DOMAIN} {
  encode zstd gzip

  @public path /api/v1/public/*
  handle @public {
    reverse_proxy {$NODE_UPSTREAM:host.docker.internal:30000} {
      header_up X-Real-IP {remote_host}
      transport http {
        response_header_timeout 10s
      }
    }
  }

  reverse_proxy {$NODE_UPSTREAM:host.docker.internal:30000}

  log {
    format json
    output file /data/logs/caddy/access.log {
      roll_size 10MB
      roll_keep 7
      roll_keep_for 168h
    }
  }
}
