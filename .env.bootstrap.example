# ──────────────────────────────────────────────────────────────────────────────
# .env.bootstrap — minimum human inputs for agentic fork provisioning
#
# Quickstart:
#   1. cp .env.bootstrap.example .env.bootstrap
#   2. Edit infra/fork.yaml::domain.root = <your Cloudflare zone> (one line).
#   3. Fill the 5 sections below.
#   4. pnpm bootstrap
#
# Spec: docs/spec/agentic-fork-bootstrap.md
# Gitignored. Never commit this file. Re-running bootstrap with the same file
# is idempotent — only changed values are re-pushed.
#
# Prereqs you must own BEFORE running bootstrap:
#   • A domain managed on Cloudflare (NOT a free *.cloudflare.dev subdomain).
#     If you don't have one, register at a domain registrar and add the zone
#     to Cloudflare. Bootstrap will fail at Cloudflare validation if the
#     CLOUDFLARE_ZONE_ID below isn't reachable with your token.
#   • A GitHub account (bot or personal) that holds the Admin role on the
#     forked repo. The PAT below must be minted from that account.
# ──────────────────────────────────────────────────────────────────────────────


# ─── 1/5 · Cherry Servers (VM provisioning) ──────────────────────────────────
# Mint: https://portal.cherryservers.com/settings/api-keys
# Authority: account-wide. Token provisions and destroys VMs.
CHERRY_AUTH_TOKEN=

# Cherry project ID — find at https://portal.cherryservers.com → your project
# → "Project ID" in the URL or project settings. Public ID, not a secret.
CHERRY_PROJECT_ID=


# ─── 2/5 · Cloudflare (DNS) ──────────────────────────────────────────────────
# Mint: https://dash.cloudflare.com/profile/api-tokens
#   → Create Token → "Edit zone DNS" template
#   → Zone Resources: Specific zone · <your domain>
# Authority: DNS records on the named zone only.
CLOUDFLARE_API_TOKEN=

# Cloudflare zone ID — find at https://dash.cloudflare.com → your domain
# → right sidebar → API → Zone ID. Public ID, not a secret. Must match
# the zone you put in infra/fork.yaml::domain.root.
CLOUDFLARE_ZONE_ID=


# ─── 3/5 · GitHub admin (mints all downstream repo + env secrets) ────────────
# The bot user MUST hold the Admin role on this repo (not a scope — a role).
# Add via: GitHub repo → Settings → Collaborators and teams → Add → Admin.
# Bootstrap validates: GITHUB_ADMIN_USERNAME == gh api user --jq .login.
#
# Token: https://github.com/settings/tokens/new (Classic PAT)
#   scopes: repo, workflow, admin:repo_hook
# (Fine-grained PAT alternative — see docs/spec/agentic-fork-bootstrap.md
#  §Fine-grained PAT alternative.)
GITHUB_ADMIN_PAT=
GITHUB_ADMIN_USERNAME=


# ─── 4/5 · OpenRouter (LLM gateway — pass-through to LiteLLM) ────────────────
# Mint: https://openrouter.ai/settings/keys
# Authority: account-level — drains your OpenRouter balance if leaked.
# See docs/spec/agentic-fork-bootstrap.md §`.env.bootstrap` Handling & Lifecycle.
OPENROUTER_API_KEY=


# ─── 5/5 · Target environment ────────────────────────────────────────────────
# v1 ships candidate-a only; preview/production via repeat invocation.
# DOMAIN is derived automatically from infra/fork.yaml::domain.root:
#   candidate-a → test.<root>     preview → preview.<root>     production → <root>
DEPLOY_ENV=candidate-a


# ─── Optional · observability (skip for v1) ──────────────────────────────────
# Grafana Cloud pass-through. If you don't have Grafana Cloud set up, leave
# these blank — observability is disabled and deploy still goes green. v2
# will mint these via a single Stack-admin token (see spec roadmap).
# Mint Loki:       https://grafana.com/orgs/<org>/api-keys (role: MetricsPublisher)
# Mint Prometheus: https://grafana.com/orgs/<org>/access-policies (metrics:write + metrics:read tokens)
GRAFANA_CLOUD_LOKI_URL=
GRAFANA_CLOUD_LOKI_USER=
GRAFANA_CLOUD_LOKI_API_KEY=
PROMETHEUS_REMOTE_WRITE_URL=
PROMETHEUS_USERNAME=
PROMETHEUS_PASSWORD=
