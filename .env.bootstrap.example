# ──────────────────────────────────────────────────────────────────────────────
# .env.bootstrap — minimum human inputs for agentic fork provisioning
#
# Usage:
#   1. cp .env.bootstrap.example .env.bootstrap
#   2. chmod 600 .env.bootstrap
#   3. Mint the 5 tokens below (links inline). Paste each value after the "=".
#   4. pnpm bootstrap
#
# Spec: docs/spec/agentic-fork-bootstrap.md
# Gitignored. Never commit this file. Re-running bootstrap with the same file
# is idempotent — only changed values are re-pushed.
# ──────────────────────────────────────────────────────────────────────────────


# ─── 1/5 · Cherry Servers (VM provisioning) ──────────────────────────────────
# Mint: https://portal.cherryservers.com/settings/api-keys
# Authority: account-wide. Token provisions and destroys VMs.
CHERRY_AUTH_TOKEN=

# Cherry project ID — find at https://portal.cherryservers.com → your project
# → "Project ID" in the URL or project settings. Public ID, not a secret.
CHERRY_PROJECT_ID=


# ─── 2/5 · Cloudflare (DNS) ──────────────────────────────────────────────────
# Mint: https://dash.cloudflare.com/profile/api-tokens
#   → Create Token → "Edit zone DNS" template
#   → Zone Resources: Specific zone · <your domain>
# Authority: DNS records on the named zone only.
CLOUDFLARE_API_TOKEN=

# Cloudflare zone ID — find at https://dash.cloudflare.com → your domain
# → right sidebar → API → Zone ID. Public ID, not a secret.
CLOUDFLARE_ZONE_ID=


# ─── 3/5 · GitHub admin (mints all downstream repo + env secrets) ────────────
# The bot user MUST hold the Admin role on this repo (not a scope — a role).
# Add via: GitHub repo → Settings → Collaborators and teams → Add → Admin.
#
# Token: https://github.com/settings/tokens/new (Classic PAT)
#   scopes: repo, workflow, admin:repo_hook
# (Fine-grained PAT alternative — see docs/spec/agentic-fork-bootstrap.md
#  §Fine-grained PAT alternative.)
GITHUB_ADMIN_PAT=
GITHUB_ADMIN_USERNAME=


# ─── 4/5 · Grafana Cloud (logs + metrics — OPTIONAL in v1) ───────────────────
# v1 accepts pre-minted tokens as pass-through. Mint at:
#   Loki:       https://grafana.com/orgs/<org>/api-keys (role: MetricsPublisher)
#   Prometheus: https://grafana.com/orgs/<org>/access-policies (metrics:write
#               + metrics:read on separate tokens)
# If left blank, observability is skipped — deploy still goes green.
# v2 will mint these via a Stack-admin token. Tracked in
#   docs/spec/agentic-fork-bootstrap.md §v1 implementation gaps.
GRAFANA_CLOUD_LOKI_URL=
GRAFANA_CLOUD_LOKI_USER=
GRAFANA_CLOUD_LOKI_API_KEY=
PROMETHEUS_REMOTE_WRITE_URL=
PROMETHEUS_USERNAME=
PROMETHEUS_PASSWORD=


# ─── 5/5 · OpenRouter (LLM gateway — pass-through to LiteLLM) ────────────────
# Mint: https://openrouter.ai/settings/keys
# Authority: account-level — drains your OpenRouter balance if leaked.
# See docs/spec/agentic-fork-bootstrap.md §.env.bootstrap Handling & Lifecycle.
OPENROUTER_API_KEY=


# ─── Operator inputs — human picks these (not secrets, just decisions) ──────
# Target environment. v1 ships candidate-a only; preview/production via repeat.
DEPLOY_ENV=candidate-a

# User-facing FQDN this deployment will serve. Must be inside the Cloudflare
# zone above (e.g. `node-template-test.cognidao.org` for zone `cognidao.org`).
# Only the human can choose this — it's their public URL.
DOMAIN=
