{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["nodes/operator/app/src/*"],
      "@/components/*": ["nodes/operator/app/src/components/*"],
      "@/shared/*": ["nodes/operator/app/src/shared/*"],
      "@/core": ["nodes/operator/app/src/core/public.ts"],
      "@/ports": ["nodes/operator/app/src/ports/index.ts"],
      "@/adapters/server": ["nodes/operator/app/src/adapters/server/index.ts"],
      "@/shared": ["nodes/operator/app/src/shared/index.ts"],
      "@features/*": ["nodes/operator/app/src/features/*"],
      "@app/*": ["nodes/operator/app/src/app/*"],
      "@adapters/*": ["nodes/operator/app/src/adapters/*"],
      "@bootstrap/*": ["nodes/operator/app/src/bootstrap/*"],
      "@components/*": ["nodes/operator/app/src/components/*"],
      "@styles/*": ["nodes/operator/app/src/styles/*"],
      "@types/*": ["nodes/operator/app/src/types/*"],
      "@assets/*": ["nodes/operator/app/src/assets/*"],
      "@tests/*": ["tests/*"]
    }
  }
}
