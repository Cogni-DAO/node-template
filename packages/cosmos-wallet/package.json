{
  "name": "@cogni/cosmos-wallet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapters/direct": {
      "types": "./dist/adapters/direct/index.d.ts",
      "import": "./dist/adapters/direct/index.js",
      "default": "./dist/adapters/direct/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"const fs=require('fs'); if(!fs.existsSync('dist/index.js')){console.error('ERROR: dist/index.js missing'); process.exit(1)}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "@cosmjs/stargate": ">=0.32.0",
    "@cosmjs/proto-signing": ">=0.32.0",
    "@cosmjs/amino": ">=0.32.0"
  },
  "peerDependenciesMeta": {
    "@cosmjs/stargate": {
      "optional": true
    },
    "@cosmjs/proto-signing": {
      "optional": true
    },
    "@cosmjs/amino": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cosmjs/stargate": "^0.32.4",
    "@cosmjs/proto-signing": "^0.32.4",
    "@cosmjs/amino": "^0.32.4",
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
