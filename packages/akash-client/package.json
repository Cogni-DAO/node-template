{
  "name": "@cogni/akash-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapters/cli": {
      "types": "./dist/adapters/cli/index.d.ts",
      "import": "./dist/adapters/cli/index.js",
      "default": "./dist/adapters/cli/index.js"
    },
    "./adapters/mock": {
      "types": "./dist/adapters/mock/index.d.ts",
      "import": "./dist/adapters/mock/index.js",
      "default": "./dist/adapters/mock/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"const fs=require('fs'); if(!fs.existsSync('dist/index.js')){console.error('ERROR: dist/index.js missing'); process.exit(1)}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cogni/cosmos-wallet": "workspace:*",
    "zod": "^3.24.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
