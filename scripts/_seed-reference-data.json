  "storeApi": {
    "createEpoch": "store.createEpoch({ nodeId, scopeId, periodStart, periodEnd, weightConfig })",
    "insertIngestionReceipts": "store.insertIngestionReceipts([InsertIngestionReceiptParams...])",
    "insertSelectionDoNothing": "store.insertSelectionDoNothing([InsertSelectionAutoParams...])",
    "insertAllocations": "store.insertAllocations([InsertAllocationParams...])",
    "insertPoolComponent": "store.insertPoolComponent(InsertPoolComponentParams)",
    "closeIngestion": "store.closeIngestion(epochId, approverSetHash, allocAlgoRef, weightConfigHash)",
    "finalizeEpoch": "store.finalizeEpoch(epochId, poolTotal)",
    "insertEpochStatement": "store.insertEpochStatement(InsertEpochStatementParams)"
  },
  "bootstrap": {
    "db": "createServiceDbClient(process.env.DATABASE_SERVICE_URL)",
    "store": "new DrizzleAttributionAdapter(db, scopeId)",
    "nodeId": "getNodeId() from repo-spec.yaml",
    "scopeId": "getScopeId() from repo-spec.yaml",
    "weightConfig": {
      "github:pr_merged": 8000,
      "github:review_submitted": 2000,
      "discord:message_sent": 500
    }
  },
