# Spike 0090: Operator Wallet Payment Chain Validation
# Copy to .env and fill in values.

# OpenRouter API key (needs credit purchase permissions)
OPENROUTER_API_KEY=sk-or-...

# Test wallet private key — SMALL AMOUNTS ONLY
# This wallet needs ~$2 USDC + trace ETH for gas on Base mainnet
OPERATOR_PRIVATE_KEY=0x...

# Second wallet address for Split treasury recipient (any Base address)
TREASURY_ADDRESS=0x...

# Base mainnet RPC (public default works, or use Alchemy/Infura for reliability)
BASE_RPC_URL=https://mainnet.base.org

# Set after running experiment 2 (splits-deploy.ts outputs this)
# SPLIT_ADDRESS=0x...
