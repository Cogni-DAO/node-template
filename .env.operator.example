# Operator deployment credentials
# Copy to .env.operator and fill in real values
# Used by: scripts/setup/provision-test-vm.sh, deploy-node skill

# Cherry Servers (VM provisioning)
CHERRY_AUTH_TOKEN=          # https://portal.cherryservers.com/settings/api-keys
CHERRY_PROJECT_ID=          # Cherry project ID (numeric)

# OpenRouter (LLM proxy — optional, LiteLLM starts without it)
OPENROUTER_API_KEY=         # https://openrouter.ai/keys

# GHCR (container registry — needs read:packages + write:packages)
GHCR_DEPLOY_TOKEN=          # gh auth token (or GitHub PAT with packages scope)
GHCR_DEPLOY_USERNAME=       # GitHub username for GHCR auth (default: Cogni-1729)

# Cloudflare (DNS — creates A records for node subdomains)
CLOUDFLARE_API_TOKEN=       # https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ZONE_ID=         # Zone ID from domain overview page

# Grafana Cloud — observability (logs + metrics)
# Create API keys at https://grafana.com/orgs/<your-org>/access-policies
LOKI_WRITE_URL=             # https://logs-prod-XXX.grafana.net/loki/api/v1/push
LOKI_USERNAME=              # Loki user ID (check datasource config in Grafana — may differ from Prometheus!)
LOKI_PASSWORD=              # API key with logs:write scope (glc_...)
PROMETHEUS_REMOTE_WRITE_URL= # https://prometheus-prod-XX-prod-REGION.grafana.net/api/prom/push
PROMETHEUS_USERNAME=        # Prometheus user ID (check datasource config in Grafana)
PROMETHEUS_PASSWORD=        # API key with metrics:write scope (glc_..., can be same token as Loki)
